# Database (Neon/Supabase PostgreSQL)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/zoo?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
